{
  "name": "szmetal-admin-panel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "types:ensure": "node -e \"require('fs').mkdirSync('src/types',{recursive:true})\"",
    "types:supabase": "node scripts/gen-supabase-types.mjs",
    "predev": "npm run copy:pdf-worker && npm run types:supabase && (npm outdated supabase || node -e \"process.exit(0)\")",
    "ci": "npm ci && npm run lint && npm run typecheck && npm run build",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "copy:pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "postbuild": "node scripts/copy-pdf-worker.mjs"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.1.1",
    "@mui/icons-material": "7.3.5",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/material": "^7.3.5",
    "@mui/material-nextjs": "7.3.5",
    "@mui/x-charts": "^8.9.0",
    "@mui/x-data-grid": "^8.10.2",
    "@mui/x-date-pickers": "^8.17.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@tanstack/react-query": "^5.87.1",
    "@tsparticles/engine": "^3.9.0",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.0",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.23.12",
    "jose": "^6.1.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "4.8.69",
    "react": "19.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.60.0",
    "react-pdf": "9.2.1",
    "use-deep-compare": "^1.3.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "axe-core": "^4.10.3",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-formatter-unix": "^9.0.1",
    "shx": "^0.4.0",
    "supabase": "^2.72.8",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "engines": {
    "node": ">=20.19 <23"
  },
  "overrides": {
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "tar": "7.5.4"
  }
}
